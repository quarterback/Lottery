{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "mkdir -p public && printf '<!doctype html><meta http-equiv=refresh content=\"0;url=/\">' > public/index.html",
  "outputDirectory": "public",
  "installCommand": "echo skip-node-install",
  "functions": {
    "api/index.py": {
      "includeFiles": "artifacts/lottery-lab/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
